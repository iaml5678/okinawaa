<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>大象班🐘 沖繩大冒險</title>
    
    <!-- 引入 Tailwind CSS & Google Fonts -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@400;700;900&display=swap" rel="stylesheet">
    
    <!-- 引入 Vue 3, Lucide Icons, SortableJS -->
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

    <style>
        body {
            font-family: 'M PLUS Rounded 1c', sans-serif;
            background-color: #F0F9FF; /* 延伸水藍色底色 */
            color: #5D4037;
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .tab-glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
        }
        .card-shadow { box-shadow: 0 8px 30px rgba(162, 223, 247, 0.2); }
        /* 拖拽時的樣式 */
        .sortable-ghost { opacity: 0.3; background: #FDCEDF; }
    </style>
</head>
<body>

<div id="app" v-cloak>
    <!-- 頁首 Banner -->
    <header class="relative w-full h-[250px] overflow-hidden bg-[#A2DFF7]">
        <!-- 這裡是你的 Banner 圖片 -->
        <img src="banner.jpg" alt="Elephant Class Banner" class="w-full h-full object-cover">
        
        <!-- Tab 按鈕 (浮動在圖片上方右下) -->
        <div class="absolute bottom-10 right-4 flex gap-2">
            <button v-for="tab in tabs" :key="tab.id" 
                    @click="activeTab = tab.id"
                    :class="['p-3 rounded-2xl transition-all tab-glass flex flex-col items-center shadow-lg', 
                             activeTab === tab.id ? 'text-[#0EA5E9] border-2 border-[#A2DFF7] scale-110' : 'text-gray-500 opacity-80']">
                <i :data-lucide="tab.icon" class="w-6 h-6"></i>
            </button>
        </div>
    </header>

    <!-- 主內容區域 (負邊距向上拉動與 Banner 銜接) -->
    <main class="relative -mt-8 bg-[#F0F9FF] rounded-t-[40px] px-4 pb-24 min-h-screen border-t-4 border-white/50">
        
        <!-- 1. 每日行程表 -->
        <div v-if="activeTab === 'schedule'" class="pt-6">
            <!-- 天氣資訊 -->
            <div class="bg-white/60 p-4 rounded-3xl mb-6 flex justify-between items-center shadow-sm">
                <div class="flex items-center gap-3">
                    <span class="text-4xl">☀️</span>
                    <div>
                        <div class="text-xl font-black">那霸 26°C</div>
                        <div class="text-xs opacity-60">體感 28°C · 晴朗冒險日</div>
                    </div>
                </div>
            </div>

            <!-- 橫向滑動日期選單 -->
            <div class="flex gap-4 overflow-x-auto no-scrollbar pb-6">
                <button v-for="(day, idx) in days" :key="idx"
                        @click="activeDateIndex = idx"
                        :class="['flex flex-col items-center min-w-[70px] p-4 rounded-3xl transition-all', 
                                 activeDateIndex === idx ? 'bg-[#FDCEDF] text-[#5D4037] shadow-inner scale-105' : 'bg-white text-gray-400']">
                    <span class="text-sm font-bold">{{ day.week }}</span>
                    <span class="text-2xl font-black">{{ day.date }}</span>
                </button>
            </div>

            <!-- 行程清單 (可拖拽排序) -->
            <div id="schedule-list" class="space-y-6">
                <div v-for="(item, index) in currentDayItems" :key="item.id" class="relative">
                    
                    <!-- 交通時間顯示 (如果不是第一個行程) -->
                    <div v-if="index >= 0" class="flex items-center gap-2 my-2 ml-10 text-xs font-bold text-blue-400/60">
                        <i data-lucide="car" class="w-4 h-4"></i>
                        <span>約 {{ item.travelTime || '15' }} 分鐘</span>
                    </div>

                    <!-- 行程卡片 -->
                    <div class="bg-white p-5 rounded-[30px] card-shadow border border-white relative overflow-hidden group active:scale-95 transition-transform"
                         @click="openMap(item.address)">
                        <!-- 航班特殊顯示 -->
                        <div v-if="item.category === '航班'" class="bg-[#E0F2FE] -m-5 mb-4 p-4 flex justify-between items-center border-b border-blue-100">
                            <div class="text-center"><div class="text-2xl font-black">TPE</div><div class="text-[10px]">12:00</div></div>
                            <div class="flex-1 border-b-2 border-dashed border-blue-300 mx-4 relative">
                                <i data-lucide="plane" class="w-4 h-4 absolute -top-2 left-1/2 -translate-x-1/2 text-blue-400"></i>
                            </div>
                            <div class="text-center"><div class="text-2xl font-black">OKA</div><div class="text-[10px]">14:30</div></div>
                        </div>

                        <div class="flex justify-between items-start">
                            <div class="flex gap-4">
                                <div :class="['w-12 h-12 rounded-2xl flex items-center justify-center', getCatColor(item.category)]">
                                    <i :data-lucide="getCatIcon(item.category)" class="w-6 h-6"></i>
                                </div>
                                <div>
                                    <h3 class="text-lg font-black">{{ item.name }}</h3>
                                    <div class="text-xs opacity-60 mt-1">
                                        <span v-if="item.time" class="mr-2">🕒 {{ item.time }}</span>
                                        <span v-if="item.price">🎫 {{ item.price }}</span>
                                    </div>
                                </div>
                            </div>
                            <button @click.stop="editItem(item)" class="p-2 text-gray-300"><i data-lucide="more-horizontal"></i></button>
                        </div>
                        <div v-if="item.note" class="mt-3 text-sm bg-gray-50 p-3 rounded-2xl border-l-4 border-[#A2DFF7]">
                            {{ item.note }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- 新增按鈕 -->
            <button @click="openAddModal" class="fixed bottom-28 right-6 w-16 h-16 bg-[#FDCEDF] rounded-full shadow-2xl flex items-center justify-center text-white active:scale-90 transition-transform z-40 border-4 border-white">
                <i data-lucide="plus" class="w-8 h-8 text-[#5D4037]"></i>
            </button>
        </div>

        <!-- 2. 資訊頁 -->
        <div v-if="activeTab === 'info'" class="pt-8 space-y-6">
            <div class="bg-white p-6 rounded-[35px] card-shadow">
                <h3 class="font-black text-xl mb-4 flex items-center gap-2 text-pink-400">
                    <i data-lucide="refresh-cw"></i> 匯率換算 (當日估算)
                </h3>
                <div class="flex items-center gap-4">
                    <input type="number" v-model="jpyInput" class="w-full p-4 bg-gray-50 rounded-2xl border-none text-xl font-bold focus:ring-2 ring-pink-200" placeholder="日幣 JPY">
                    <i data-lucide="arrow-right" class="text-gray-300"></i>
                    <div class="w-full p-4 bg-[#F0F9FF] rounded-2xl text-xl font-bold text-blue-500">
                        NT$ {{ (jpyInput * 0.21).toFixed(0) }}
                    </div>
                </div>
            </div>

            <div v-for="info in travelInfo" :key="info.title" class="bg-white p-6 rounded-[35px] card-shadow">
                <h3 class="font-black text-lg mb-2 flex items-center gap-2">
                    <i :data-lucide="info.icon" class="text-[#A2DFF7]"></i> {{ info.title }}
                </h3>
                <p class="text-sm opacity-70 leading-relaxed" v-html="info.content"></p>
                <button v-if="info.address" @click="openMap(info.address)" class="mt-4 w-full py-3 bg-[#E0F2FE] text-blue-500 rounded-2xl font-bold text-sm">
                    立即導航
                </button>
            </div>
        </div>

        <!-- 3. 購物清單 -->
        <div v-if="activeTab === 'shopping'" class="pt-8 grid grid-cols-2 gap-4">
            <div v-for="shop in shoppingList" :key="shop.id" class="bg-white p-3 rounded-[30px] card-shadow">
                <div class="w-full h-32 bg-gray-100 rounded-[25px] overflow-hidden mb-3">
                    <img :src="shop.img || 'https://via.placeholder.com/150?text=Elephant'" class="w-full h-full object-cover">
                </div>
                <div class="font-black text-sm px-2">{{ shop.name }}</div>
            </div>
            <button @click="addShopItem" class="fixed bottom-28 right-6 w-16 h-16 bg-[#A2DFF7] rounded-full shadow-2xl flex items-center justify-center text-white border-4 border-white">
                <i data-lucide="plus" class="w-8 h-8 text-[#5D4037]"></i>
            </button>
        </div>

        <!-- 4. 花費記帳 -->
        <div v-if="activeTab === 'expense'" class="pt-8">
            <div class="bg-[#5D4037] text-white p-8 rounded-[40px] mb-8 shadow-xl relative overflow-hidden">
                <div class="text-sm opacity-60">總支出總計 (JPY)</div>
                <div class="text-4xl font-black mt-2">¥ {{ totalExpense }}</div>
                <div class="absolute -right-10 -bottom-10 text-9xl opacity-10">🐘</div>
            </div>
            <div class="space-y-4">
                <div v-for="exp in expenses" :key="exp.id" class="bg-white p-5 rounded-[30px] flex justify-between items-center shadow-sm border border-white">
                    <div class="flex gap-4 items-center">
                        <div class="w-10 h-10 rounded-xl bg-pink-50 text-pink-400 flex items-center justify-center">
                            <i data-lucide="credit-card" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <div class="font-black">{{ exp.name }}</div>
                            <div class="text-[10px] opacity-40 uppercase">{{ exp.category }} · {{ exp.method }}</div>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="font-black text-pink-500">¥ {{ exp.amount }}</div>
                        <div class="text-[10px] opacity-40">{{ exp.date }}</div>
                    </div>
                </div>
            </div>
            <button @click="addExpense" class="fixed bottom-28 right-6 w-16 h-16 bg-[#FFD93D] rounded-full shadow-2xl flex items-center justify-center text-white border-4 border-white">
                <i data-lucide="plus" class="w-8 h-8 text-[#5D4037]"></i>
            </button>
        </div>

    </main>

    <!-- 底部圓形裝飾導航 (美觀用) -->
    <nav class="fixed bottom-6 left-6 right-6 h-16 bg-white/80 backdrop-blur-xl rounded-full shadow-2xl flex items-center justify-around border border-white/50 z-30">
        <div v-for="tab in tabs" @click="activeTab = tab.id" class="cursor-pointer transition-all" :class="activeTab === tab.id ? 'scale-125 text-[#A2DFF7]' : 'text-gray-300'">
            <i :data-lucide="tab.icon"></i>
        </div>
    </nav>
</div>

<script>
    const { createApp, ref, reactive, onMounted, computed, watch, nextTick } = Vue;

    createApp({
        setup() {
            const activeTab = ref('schedule');
            const activeDateIndex = ref(0);
            const jpyInput = ref(0);
            
            const tabs = [
                { id: 'schedule', icon: 'map-pin' },
                { id: 'info', icon: 'info' },
                { id: 'shopping', icon: 'shopping-basket' },
                { id: 'expense', icon: 'wallet' }
            ];

            const days = [
                { week: 'Thu', date: '9' },
                { week: 'Fri', date: '10' },
                { week: 'Sat', date: '11' },
                { week: 'Sun', date: '12' },
                { week: 'Mon', date: '13' }
            ];

            const scheduleItems = reactive([
                { id: 1, day: 0, category: '航班', name: '星宇航空 JX870', time: '12:00', address: '那霸機場', note: '大象班起飛囉！' },
                { id: 2, day: 0, category: '住宿', name: '恩納村海景別墅', time: '18:00', address: '1854 Afuso, Onna', note: 'Check-in 第一晚' }
            ]);

            const expenses = reactive([
                { id: 1, name: 'Roins 和牛燒肉', amount: 15000, category: '飲食', method: '信用卡', date: '5/12' }
            ]);

            const shoppingList = reactive([
                { id: 1, name: '沖繩限定海鹽餅乾', img: '' }
            ]);

            const travelInfo = [
                { title: '航班資訊 (去程)', icon: 'plane', content: 'JX870 · TPE -> OKA <br> 起飛 12:00 / 抵達 14:30' },
                { title: '住宿飯店', icon: 'home', address: '1854 Afuso, Onna', content: '民宿グランディオーソ沖縄<br>電話：+81 98-966-1234' },
                { title: '租車資訊', icon: 'car', address: 'OTS 租車 那霸機場店', content: 'OTS 租車 · 五人座小黃車' },
                { title: '緊急求助', icon: 'alert-circle', content: '警察：110 · 救護車：119' }
            ];

            const currentDayItems = computed(() => {
                return scheduleItems.filter(item => item.day === activeDateIndex.value);
            });

            const totalExpense = computed(() => {
                return expenses.reduce((sum, exp) => sum + exp.amount, 0);
            });

            const openMap = (address) => {
                if (!address) return;
                window.open(`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(address)}`, '_blank');
            };

            const getCatIcon = (cat) => {
                const icons = { '景點': 'map', '住宿': 'home', '美食': 'utensils', '購物': 'shopping-bag', '航班': 'plane', '其他': 'more-horizontal' };
                return icons[cat] || 'star';
            };

            const getCatColor = (cat) => {
                const colors = { '景點': 'bg-green-50 text-green-400', '住宿': 'bg-blue-50 text-blue-400', '美食': 'bg-orange-50 text-orange-400', '購物': 'bg-pink-50 text-pink-400', '航班': 'bg-indigo-50 text-indigo-400' };
                return colors[cat] || 'bg-gray-50';
            };

            const initDraggable = () => {
                const el = document.getElementById('schedule-list');
                if (el) {
                    Sortable.create(el, {
                        animation: 150,
                        ghostClass: 'sortable-ghost',
                        onEnd: () => { console.log('排序已更新'); }
                    });
                }
            };

            onMounted(() => {
                lucide.createIcons();
                initDraggable();
            });

            watch(activeTab, () => {
                nextTick(() => { lucide.createIcons(); if (activeTab.value === 'schedule') initDraggable(); });
            });

            return {
                activeTab, activeDateIndex, tabs, days, scheduleItems, currentDayItems, 
                travelInfo, expenses, shoppingList, jpyInput, totalExpense,
                openMap, getCatIcon, getCatColor
            };
        }
    }).mount('#app');
</script>

</body>
</html>
